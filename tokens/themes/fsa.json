{
  "theme": {
    "brand": {
      "navy":    { "$type": "color", "$value": "#142745" },
      "crimson": { "$type": "color", "$value": "#FF295B" },
      "blush":   { "$type": "color", "$value": "#FEEBE5" },
      "sky":     { "$type": "color", "$value": "#E9F2FF" },
      "mist":    { "$type": "color", "$value": "#F6FAFF" },
      "slate":   { "$type": "color", "$value": "#375481" }
    },
    "background":             { "$type": "color",  "$value": "{color.white}" },
    "foreground":             { "$type": "color",  "$value": "{theme.brand.navy}" },
    "muted":                  { "$type": "color",  "$value": "{theme.brand.mist}" },
    "muted-foreground":       { "$type": "color",  "$value": "{theme.brand.slate}" },
    "card":                   { "$type": "color",  "$value": "{color.white}" },
    "card-foreground":        { "$type": "color",  "$value": "{theme.brand.navy}" },
    "popover":                { "$type": "color",  "$value": "{color.white}" },
    "popover-foreground":     { "$type": "color",  "$value": "{theme.brand.navy}" },
    "border":                 { "$type": "color",  "$value": "{theme.brand.sky}" },
    "input":                  { "$type": "color",  "$value": "{theme.brand.sky}" },
    "primary":                { "$type": "color",  "$value": "{theme.brand.crimson}" },
    "primary-foreground":     { "$type": "color",  "$value": "{color.white}" },
    "secondary":              { "$type": "color",  "$value": "{theme.brand.sky}" },
    "secondary-foreground":   { "$type": "color",  "$value": "{theme.brand.navy}" },
    "accent":                 { "$type": "color",  "$value": "{theme.brand.blush}" },
    "accent-foreground":      { "$type": "color",  "$value": "{theme.brand.navy}" },
    "destructive":            { "$type": "color",  "$value": "{color.rose.500}" },
    "destructive-foreground": { "$type": "color",  "$value": "{color.white}" },
    "ring":                   { "$type": "color",  "$value": "{theme.brand.crimson}" },
    "radius":                 { "$type": "number", "$value": 6 },
    "font-sans":              { "$type": "string", "$value": "Plus Jakarta Sans" },
    "font-display":           { "$type": "string", "$value": "Plus Jakarta Sans" },
    "chart-1":                { "$type": "color",  "$value": "{color.chart.1}" },
    "chart-2":                { "$type": "color",  "$value": "{color.chart.2}" },
    "chart-3":                { "$type": "color",  "$value": "{color.chart.3}" },
    "chart-4":                { "$type": "color",  "$value": "{color.chart.4}" },
    "chart-5":                { "$type": "color",  "$value": "{color.chart.5}" },
    "sidebar-background":     { "$type": "color",  "$value": "{color.white}" },
    "sidebar-foreground":     { "$type": "color",  "$value": "{theme.brand.navy}" },
    "sidebar-primary":        { "$type": "color",  "$value": "{theme.brand.crimson}" },
    "sidebar-primary-foreground": { "$type": "color", "$value": "{color.white}" },
    "sidebar-accent":         { "$type": "color",  "$value": "{theme.brand.blush}" },
    "sidebar-accent-foreground": { "$type": "color", "$value": "{theme.brand.navy}" },
    "sidebar-border":         { "$type": "color",  "$value": "{theme.brand.sky}" },
    "sidebar-ring":           { "$type": "color",  "$value": "{theme.brand.crimson}" }
  }
}
