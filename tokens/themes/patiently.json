{
  "theme": {
    "brand": {
      "navy":  { "$type": "color", "$value": "#121E3D" },
      "lime":  { "$type": "color", "$value": "#D9FD6F" },
      "iris":  { "$type": "color", "$value": "#8B93F7" },
      "mint":  { "$type": "color", "$value": "#EFFEC2" },
      "cream": { "$type": "color", "$value": "#F9F8F5" },
      "sand":  { "$type": "color", "$value": "#F0EFE9" },
      "stone": { "$type": "color", "$value": "#E8E5DE" },
      "ash":   { "$type": "color", "$value": "#5B6070" }
    },
    "background":             { "$type": "color",  "$value": "{theme.brand.cream}" },
    "foreground":             { "$type": "color",  "$value": "{theme.brand.navy}" },
    "muted":                  { "$type": "color",  "$value": "{theme.brand.sand}" },
    "muted-foreground":       { "$type": "color",  "$value": "{theme.brand.ash}" },
    "card":                   { "$type": "color",  "$value": "{color.white}" },
    "card-foreground":        { "$type": "color",  "$value": "{theme.brand.navy}" },
    "popover":                { "$type": "color",  "$value": "{color.white}" },
    "popover-foreground":     { "$type": "color",  "$value": "{theme.brand.navy}" },
    "border":                 { "$type": "color",  "$value": "{theme.brand.stone}" },
    "input":                  { "$type": "color",  "$value": "{theme.brand.stone}" },
    "primary":                { "$type": "color",  "$value": "{theme.brand.navy}" },
    "primary-foreground":     { "$type": "color",  "$value": "{theme.brand.lime}" },
    "secondary":              { "$type": "color",  "$value": "{theme.brand.iris}" },
    "secondary-foreground":   { "$type": "color",  "$value": "{theme.brand.navy}" },
    "accent":                 { "$type": "color",  "$value": "{theme.brand.mint}" },
    "accent-foreground":      { "$type": "color",  "$value": "{theme.brand.navy}" },
    "destructive":            { "$type": "color",  "$value": "{color.red.600}" },
    "destructive-foreground": { "$type": "color",  "$value": "{color.white}" },
    "ring":                   { "$type": "color",  "$value": "{theme.brand.iris}" },
    "radius":                 { "$type": "number", "$value": 12 },
    "font-sans":              { "$type": "string", "$value": "Figtree" },
    "font-display":           { "$type": "string", "$value": "Instrument Serif" },
    "chart-1":                { "$type": "color",  "$value": "{color.chart.1}" },
    "chart-2":                { "$type": "color",  "$value": "{color.chart.2}" },
    "chart-3":                { "$type": "color",  "$value": "{color.chart.3}" },
    "chart-4":                { "$type": "color",  "$value": "{color.chart.4}" },
    "chart-5":                { "$type": "color",  "$value": "{color.chart.5}" },
    "sidebar-background":     { "$type": "color",  "$value": "{color.white}" },
    "sidebar-foreground":     { "$type": "color",  "$value": "{theme.brand.navy}" },
    "sidebar-primary":        { "$type": "color",  "$value": "{theme.brand.navy}" },
    "sidebar-primary-foreground": { "$type": "color", "$value": "{theme.brand.lime}" },
    "sidebar-accent":         { "$type": "color",  "$value": "{theme.brand.mint}" },
    "sidebar-accent-foreground": { "$type": "color", "$value": "{theme.brand.navy}" },
    "sidebar-border":         { "$type": "color",  "$value": "{theme.brand.stone}" },
    "sidebar-ring":           { "$type": "color",  "$value": "{theme.brand.iris}" }
  }
}
